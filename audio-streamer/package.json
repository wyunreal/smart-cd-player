{
  "name": "audio-streamer",
  "version": "1.0.63",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc && cp -r src/public dist/src/public && esbuild node_modules/@wasm-audio-decoders/flac/index.js --bundle --format=esm --outfile=dist/src/public/flac-decoder.esm.js",
    "start": "node dist/src/main.js",
    "dev": "tsx src/main.ts"
  },
  "dependencies": {
    "@wasm-audio-decoders/flac": "^0.2.10",
    "express": "^4.18.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
