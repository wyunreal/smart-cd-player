{
  "name": "audio-streamer",
  "version": "1.0.5",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc && cp -r src/public dist/src/public && esbuild node_modules/mediasoup-client/lib/index.js --bundle --platform=browser --minify --outfile=dist/src/public/mediasoup-client.min.js",
    "start": "node dist/src/main.js",
    "dev": "tsx src/main.ts"
  },
  "dependencies": {
    "express": "^4.18.0",
    "mediasoup": "^3.14.0",
    "mediasoup-client": "^3.7.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.21.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
